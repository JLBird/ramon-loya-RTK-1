# =============================================
# RTK-1 Environment Variables (copy to .env)
# =============================================

# Anthropic (Claude) — required for the orchestrator
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Local model target (Ollama)
OLLAMA_HOST=http://localhost:11434

# Security & rate limiting (used by FastAPI middleware)
RATE_LIMIT_PER_MINUTE=60

# Logging level (DEBUG for development, INFO for production)
LOG_LEVEL=INFO

# Optional: Future cloud targets or extra keys
# OPENAI_API_KEY=sk-...
# GROK_API_KEY=...